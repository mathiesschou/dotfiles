// Niri configuration

// Output/display settings
output "Virtual-1" {
    scale 2.0
}

// Window appearance
layout {
    focus-ring {
        width 1.5
    }
    border {
        width 1.5
    }
}

window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
    draw-border-with-background false
}

prefer-no-csd

// Input settings
input {
    keyboard {
        xkb {
            layout "us"
        }
        repeat-delay 200
        repeat-rate 35
    }
}

// Keybindings - using Alt as modifier to avoid Cmd conflicts
binds {
    // Help
    Alt+Shift+Slash { show-hotkey-overlay; }

    // Terminal
    Alt+Return { spawn "ghostty"; }
    Alt+T { spawn "ghostty"; }

    // App launcher
    Alt+D { spawn "fuzzel"; }

    // Close window
    Alt+Q { close-window; }

    // Focus
    Alt+H { focus-column-left; }
    Alt+J { focus-window-down; }
    Alt+K { focus-window-up; }
    Alt+L { focus-column-right; }

    // Move windows
    Alt+Shift+H { move-column-left; }
    Alt+Shift+J { move-window-down; }
    Alt+Shift+K { move-window-up; }
    Alt+Shift+L { move-column-right; }

    // Workspaces
    Super+J { focus-workspace-down; }
    Super+K { focus-workspace-up; }
    Super+Shift+J { move-column-to-workspace-down; }
    Super+Shift+K { move-column-to-workspace-up; }

    // Layout
    Alt+F { maximize-column; }
    Alt+Shift+F { fullscreen-window; }

    // Exit
    Alt+Shift+E { quit; }
}
