theme = GruvboxDark

# Font
font-family = "MesloLGS NF"
font-size = 20

# Cursor
cursor-style = block
cursor-style-blink = true

# Window
window-padding-x = 10
window-padding-y = 10
window-decoration = true

# Other
confirm-close-surface = false
shell-integration-features = no-cursor
keybind = shift+enter=text:\x1b\r
